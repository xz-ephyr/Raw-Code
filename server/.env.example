# ==========================================
# Doktor Backend Server — Standalone Configuration
# ==========================================
# Copy this file to .env and adjust as needed.
# The server is fully independent from the frontend.
# Run: npm run dev

# Port the server listens on (default: 3001)
PORT=3001

# SQLite database file location
# Default: <project_root>/server/data/doktor.db
# DATA_DIR=./data

# Optional API key to secure backend endpoints
# Frontend must send this in the X-Api-Key header
# API_KEY=my-secret-key

# go-crawl URL for content tools and server-side search fallback
# GO_CRAWL_URL=http://localhost:8080

# Connector encryption key (shared across all connectors, 32 bytes base64-encoded)
CONNECTOR_ENCRYPTION_KEY=your-base64-32-byte-key-here
# Backward compat alias for CONNECTOR_ENCRYPTION_KEY
# GMAIL_ENCRYPTION_KEY=your-base64-32-byte-key-here

# Google OAuth credentials (shared by Gmail + YouTube)
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_OAUTH_REDIRECT_URI=http://localhost:3001/auth/gmail/callback
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:3001/auth/youtube/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3001/auth/github/callback

# Reddit OAuth
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_OAUTH_REDIRECT_URI=http://localhost:3001/auth/reddit/callback

# Twitter/X OAuth 2.0
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_OAUTH_REDIRECT_URI=http://localhost:3001/auth/twitter/callback

# Telegram Bot Token (alternative: set at runtime via UI)
# TELEGRAM_BOT_TOKEN=
