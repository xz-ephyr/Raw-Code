{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "paths": {
      "@/*": ["./src/*"],
      "@core/*": ["./core/*"],
      "@doktor/tool-runtime": ["./packages/tool-runtime/src"],
      "@doktor/tool-runtime/*": ["./packages/tool-runtime/src/*"],
      "@doktor/subagent": ["./packages/subagent/src"],
      "@doktor/subagent/*": ["./packages/subagent/src/*"]
    }
  },
  "include": ["src", "core", "packages/tool-runtime", "packages/subagent"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
