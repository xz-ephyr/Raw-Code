{
  "name": "doktor",
  "version": "0.15.0",
  "type": "module",
  "private": true,
  "bin": {
    "doktor": "./bin/doktor.js"
  },
  "scripts": {
    "dev": "vite",
    "server": "npm run dev --prefix server",
    "crawler": "cd crawler && go run ./cmd/server",
    "dev:all": "concurrently -n crawler,server,vite -c yellow,green,cyan --hide crawler \"npm run crawler\" \"npm run server\" \"npm run dev\"",
    "build": "vite build",
    "desktop:prebuild": "npm run build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md,json}\"",
    "type-check": "tsc --noEmit",
    "selftest": "tsx tests/selftest/run.ts",
    "selftest:full": "tsx tests/selftest/run.ts --full",
    "analyze": "fallow"
  },
